rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: users can read/write their own profile
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Journeys: owner can read/write, partners can read
    match /journeys/{journeyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // Milestones: anyone authenticated can read, owner can write
    match /milestones/{milestoneId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Milestone completions: anyone authenticated can read/write
    match /milestone_completions/{completionId} {
      allow read, write: if request.auth != null;
    }

    // Journal entries: anyone authenticated can read, write their own
    match /journal_entries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Invite codes: anyone authenticated can read, owner can create
    match /invite_codes/{codeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Partnerships: anyone authenticated can read/create
    match /partnerships/{partnershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Reward claims: anyone authenticated can read/write
    match /reward_claims/{claimId} {
      allow read, write: if request.auth != null;
    }

    // Journal reactions: anyone authenticated can read/write
    match /journal_reactions/{reactionId} {
      allow read, write: if request.auth != null;
    }
  }
}
